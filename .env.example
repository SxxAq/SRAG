# SRAG Main Configuration

# Google Gemini API Key (required)
GEMINI_API_KEY=your-google-api-key-here

# SRAG Core Configuration
SRAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
SRAG_LLM_BACKEND=gemini
SRAG_LLM_MODEL=gemini-2.5-flash
SRAG_VECTOR_DB_TYPE=chroma
SRAG_VECTOR_DB_PATH=./data/vector_store

# Chunking
SRAG_CHUNK_SIZE=1000
SRAG_CHUNK_OVERLAP=200

# Retrieval
SRAG_TOP_K=5
SRAG_SIMILARITY_THRESHOLD=0.0

# Logging
SRAG_LOG_LEVEL=INFO

# Backend Database (Docker: sqlite, Production: postgresql)
DATABASE_URL=sqlite:///./data/chat_history.db

# Frontend API (automatically proxied in Docker)
VITE_API_BASE_URL=/api

# Frontend
FRONTEND_PORT=3000
