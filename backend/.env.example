# Backend Environment Configuration

# Database
DATABASE_URL=sqlite:///./data/chat_history.db
# For PostgreSQL: postgresql://user:password@localhost/srag_db

# SRAG Configuration (inherits from main .env if not set here)
SRAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
SRAG_LLM_BACKEND=gemini
SRAG_LLM_MODEL=gemini-2.5-flash
SRAG_VECTOR_DB_PATH=./data/vector_store
SRAG_CHUNK_SIZE=1000
SRAG_CHUNK_OVERLAP=200
SRAG_TOP_K=5

# Google Gemini API Key
GEMINI_API_KEY=your-api-key-here

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
